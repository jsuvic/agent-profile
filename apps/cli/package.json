{
  "name": "@agent-profile/cli",
  "version": "0.4.3",
  "description": "Command-line interface for Agent Profile Compiler.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsuvic/agent-profile.git",
    "directory": "apps/cli"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-profile": "dist/index.js"
  },
  "files": [
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/index.js",
    "dist/index.js.map"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json && node bundle.mjs",
    "check": "tsc -b tsconfig.json && tsc -p tsconfig.test.json --noEmit",
    "test": "tsc -b tsconfig.json && node bundle.mjs && tsx --tsconfig tsconfig.test.json --test src/*.test.ts",
    "lint": "tsc -b tsconfig.json && tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@agent-profile/compiler": "0.3.0",
    "@agent-profile/core": "0.2.0",
    "@agent-profile/doctor": "0.3.0",
    "@agent-profile/scanner": "0.2.0",
    "@agent-profile/web": "0.4.3",
    "@clack/prompts": "1.7.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
