{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-profile.local/schemas/ai-profile.schema.json",
  "title": "Agent Profile",
  "description": "Version 1 canonical profile for Agent Profile Compiler.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "profile", "stack", "clients", "workflow"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["languages", "frameworks", "packageManagers", "testing"],
      "properties": {
        "languages": {
          "$ref": "#/definitions/nonEmptySlugArray"
        },
        "frameworks": {
          "$ref": "#/definitions/slugArray"
        },
        "packageManagers": {
          "$ref": "#/definitions/slugArray"
        },
        "testing": {
          "$ref": "#/definitions/slugArray"
        }
      }
    },
    "clients": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tabnine", "codex", "claude"],
      "properties": {
        "tabnine": {
          "$ref": "#/definitions/client"
        },
        "codex": {
          "$ref": "#/definitions/client"
        },
        "claude": {
          "$ref": "#/definitions/client"
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/definitions/safetyMode"
        },
        "requiresSandbox": {
          "type": "boolean"
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sdd", "tdd", "finalReview"],
      "properties": {
        "sdd": {
          "type": "boolean"
        },
        "tdd": {
          "type": "boolean"
        },
        "finalReview": {
          "type": "boolean"
        },
        "codeReview": {
          "type": "boolean"
        },
        "refactoring": {
          "type": "boolean"
        },
        "documentation": {
          "type": "boolean"
        },
        "memoryGuidance": {
          "type": "boolean"
        },
        "loggingGuidance": {
          "type": "boolean"
        },
        "subagentDrivenDevelopment": {
          "type": "boolean"
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skills": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "packs": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "base",
                  "review",
                  "advanced-review",
                  "automation",
                  "mcp-recommendations"
                ]
              }
            }
          }
        },
        "delegation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "subagents": {
              "$ref": "#/definitions/subagents"
            }
          }
        },
        "hooks": {
          "$ref": "#/definitions/hooks"
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filesystem": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read": {
              "$ref": "#/definitions/permissionMode"
            },
            "write": {
              "$ref": "#/definitions/permissionMode"
            }
          }
        },
        "shell": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "run": {
              "$ref": "#/definitions/permissionMode"
            }
          }
        },
        "secrets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "access": {
              "type": "string",
              "const": "deny"
            }
          }
        },
        "dependencies": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "install": {
              "$ref": "#/definitions/permissionMode"
            }
          }
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "external": {
              "$ref": "#/definitions/permissionMode"
            }
          }
        },
        "production": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "access": {
              "type": "string",
              "const": "deny"
            }
          }
        }
      }
    },
    "subagentPolicy": {
      "$ref": "#/definitions/subagentPolicy"
    }
  },
  "definitions": {
    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "permissionMode": {
      "type": "string",
      "enum": ["allow", "ask", "deny"]
    },
    "safetyMode": {
      "type": "string",
      "enum": ["guarded", "balanced", "autonomous", "plan-only"]
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "slugArray": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/slug"
      }
    },
    "nonEmptySlugArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/slug"
      }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "advisory": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "final-review-reminder",
              "context-injection",
              "pre-compact-checkpoint"
            ]
          }
        }
      },
      "if": {
        "properties": {
          "enabled": {
            "const": false
          }
        },
        "required": ["enabled"]
      },
      "then": {
        "properties": {
          "advisory": {
            "type": "array",
            "maxItems": 0
          }
        }
      }
    },
    "subagents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "defaults": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxConcurrent": {
              "type": "integer",
              "minimum": 1
            },
            "maxDepth": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/subagent"
          }
        },
        "packs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["reviewer-subagents"]
          }
        }
      },
      "if": {
        "properties": {
          "enabled": {
            "const": true
          }
        },
        "required": ["enabled"]
      },
      "then": {
        "anyOf": [
          {
            "required": ["agents"],
            "properties": {
              "agents": {
                "type": "array",
                "minItems": 1
              }
            }
          },
          {
            "required": ["packs"],
            "properties": {
              "packs": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        ]
      },
      "else": {
        "properties": {
          "packs": {
            "type": "array",
            "maxItems": 0
          }
        }
      }
    },
    "subagentPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "roles": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "implementer": { "$ref": "#/definitions/subagentPolicyRole" },
            "complex-implementer": {
              "$ref": "#/definitions/subagentPolicyRole"
            },
            "explorer": { "$ref": "#/definitions/subagentPolicyRole" },
            "spec-reviewer": { "$ref": "#/definitions/subagentPolicyRole" },
            "quality-reviewer": { "$ref": "#/definitions/subagentPolicyRole" },
            "critical-reviewer": { "$ref": "#/definitions/subagentPolicyRole" },
            "architect": { "$ref": "#/definitions/subagentPolicyRole" },
            "grill": { "$ref": "#/definitions/subagentPolicyRole" },
            "mechanical": { "$ref": "#/definitions/subagentPolicyRole" }
          }
        },
        "orchestration": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxConcurrentThreads": {
              "type": "integer"
            },
            "maxDepth": {
              "type": "integer"
            },
            "parallelWrites": {
              "type": "boolean"
            }
          }
        },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "handoff": {
              "type": "string",
              "enum": ["task-capsule"]
            },
            "memory": {
              "type": "string",
              "enum": ["targeted"]
            },
            "indexed": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["preferred", "off"]
                },
                "provider": {
                  "type": "string",
                  "enum": ["cce"]
                }
              }
            }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "summary": {
              "type": "string",
              "enum": ["required"]
            },
            "localTrace": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "retention": {
                  "type": "integer"
                }
              }
            }
          }
        }
      }
    },
    "subagentPolicyCapability": {
      "type": "string",
      "enum": ["efficient", "balanced", "strongest"]
    },
    "subagentPolicyEffort": {
      "type": "string",
      "enum": ["low", "medium", "high", "extra-high"]
    },
    "subagentPolicyRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability", "effort"],
      "properties": {
        "capability": {
          "$ref": "#/definitions/subagentPolicyCapability"
        },
        "effort": {
          "$ref": "#/definitions/subagentPolicyEffort"
        },
        "overrides": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "codex": {
              "$ref": "#/definitions/subagentPolicyCodexRoleOverride"
            },
            "claude": {
              "$ref": "#/definitions/subagentPolicyClaudeRoleOverride"
            }
          }
        }
      }
    },
    "subagentPolicyCodexRoleOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string"
        },
        "effort": {
          "$ref": "#/definitions/subagentPolicyEffort"
        }
      }
    },
    "subagentPolicyClaudeRoleOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string"
        },
        "effort": {
          "$ref": "#/definitions/subagentPolicyEffort"
        }
      }
    },
    "subagent": {
      "oneOf": [
        { "$ref": "#/definitions/subagentTemplateRef" },
        { "$ref": "#/definitions/subagentInline" }
      ]
    },
    "subagentTemplateRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["useTemplate"],
      "properties": {
        "useTemplate": {
          "type": "string",
          "enum": ["implementer", "spec-reviewer", "code-quality-reviewer"]
        }
      }
    },
    "subagentInline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "purpose", "prompt", "toolScope"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "not": {
            "enum": [
              "default",
              "worker",
              "explorer",
              "explore",
              "plan",
              "general-purpose",
              "codebase_investigator",
              "remote-codebase-investigator",
              "generalist",
              "browser_agent"
            ]
          }
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\r\\n]+$"
        },
        "purpose": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\r\\n]+$"
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "toolScope": {
          "type": "string",
          "enum": ["read-only", "workspace-write"]
        },
        "modelPreference": {
          "type": "string",
          "enum": ["inherit", "fast", "balanced", "capable"]
        },
        "maxTurns": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutMinutes": {
          "type": "integer",
          "minimum": 1
        },
        "mcpServers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 0
        }
      }
    }
  }
}
