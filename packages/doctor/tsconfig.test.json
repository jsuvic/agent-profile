{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "rootDir": "../..",
    "paths": {
      "@agent-profile/compiler": [
        "../compiler/src/index.ts"
      ],
      "@agent-profile/core": [
        "../core/src/index.ts"
      ],
      "@agent-profile/schemas/*": [
        "../schemas/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": []
}
