{
  "name": "@agent-profile/compiler",
  "version": "0.3.0",
  "description": "Deterministic output compiler for Agent Profile Compiler.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "check": "tsc -b tsconfig.json && tsc -p tsconfig.test.json --noEmit",
    "test": "tsc -b tsconfig.json && tsx --tsconfig tsconfig.test.json --test src/*.test.ts",
    "lint": "tsc -b tsconfig.json && tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@agent-profile/core": "0.2.0"
  }
}
